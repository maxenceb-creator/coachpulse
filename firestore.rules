rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function staffPath(uid) {
      return /databases/$(database)/documents/staff_members/$(uid);
    }

    function staffExists() {
      return signedIn() && exists(staffPath(request.auth.uid));
    }

    function staffDoc() {
      return get(staffPath(request.auth.uid));
    }

    function staffStatus() {
      return staffExists() && staffDoc().data.keys().hasAny(['status']) ? staffDoc().data.status : 'ACTIVE';
    }

    function hasActiveStaffProfile() {
      return staffExists() && !(staffStatus() in ['ARCHIVED', 'INACTIVE', 'DISABLED']);
    }

    function role() {
      return hasActiveStaffProfile() && staffDoc().data.keys().hasAny(['role']) ? staffDoc().data.role : 'NONE';
    }

    function hasRole(roles) {
      return hasActiveStaffProfile() && role() in roles;
    }

    function permissionLevel() {
      return hasActiveStaffProfile() && staffDoc().data.keys().hasAny(['permissionLevel']) ? staffDoc().data.permissionLevel : legacyPermissionFromRole();
    }

    function legacyPermissionFromRole() {
      return role() == 'ADMIN' ? 'ADMIN'
        : (role() in ['RESPONSABLE', 'RESPONSABLE_CATEGORIE'] ? 'EDITEUR'
        : (role() in ['LECTURE', 'LECTURE_SEULE', 'OBSERVATEUR', 'OBSERVATEUR_STAFF', 'JOUEUSE_PARENT'] ? 'LECTEUR' : 'SAISIE'));
    }

    function canReadData() {
      return hasActiveStaffProfile() && permissionLevel() in ['LECTEUR', 'SAISIE', 'EDITEUR', 'ADMIN'];
    }

    function canWriteData() {
      return hasActiveStaffProfile() && permissionLevel() in ['SAISIE', 'EDITEUR', 'ADMIN'];
    }

    function canEditData() {
      return hasActiveStaffProfile() && permissionLevel() in ['EDITEUR', 'ADMIN'];
    }

    function canAccessModule(moduleId) {
      return hasActiveStaffProfile()
        && (
          permissionLevel() == 'ADMIN'
          || role() == 'ADMIN'
          || profileList('allowedModules').size() == 0
          || profileList('allowedModules').hasAny([moduleId])
        );
    }

    function canManageUsers() {
      return canEditData() && canAccessModule('admin');
    }

    function canManageCoreData() {
      return canEditData() && (canAccessModule('database') || canAccessModule('dataHub'));
    }

    function canWriteSportData() {
      return canWriteData();
    }

    function canWritePhysicalData() {
      return canWriteData();
    }

    function canReadMedicalData() {
      return canReadData() && canAccessModule('medical');
    }

    function canReadPlayerProfileData(data) {
      return canReadData() && canAccessModule('playerProfile') && canAccessScopedData(data);
    }

    function canWriteMedicalData() {
      return canWriteData() && canAccessModule('medical');
    }

    function profileList(field) {
      return staffDoc().data.keys().hasAny([field]) && staffDoc().data[field] is list ? staffDoc().data[field] : [];
    }

    function hasTeamScope() {
      return profileList('teamIds').size() > 0
        || profileList('allowedTeamIds').size() > 0
        || profileList('authorizedTeams').size() > 0
        || profileList('equipesAutorisees').size() > 0;
    }

    function canAccessTeam(teamId) {
      return permissionLevel() == 'ADMIN'
        || !hasTeamScope()
        || profileList('teamIds').hasAny([teamId])
        || profileList('allowedTeamIds').hasAny([teamId])
        || profileList('authorizedTeams').hasAny([teamId])
        || profileList('equipesAutorisees').hasAny([teamId]);
    }

    function hasPlayerScope() {
      return profileList('playerIds').size() > 0 || profileList('allowedPlayerIds').size() > 0;
    }

    function canAccessPlayerId(playerId) {
      return permissionLevel() == 'ADMIN'
        || profileList('playerIds').size() == 0 && profileList('allowedPlayerIds').size() == 0
        || profileList('playerIds').hasAny([playerId])
        || profileList('allowedPlayerIds').hasAny([playerId]);
    }

    function valueOrEmpty(data, key) {
      return data.keys().hasAny([key]) ? data[key] : '';
    }

    function hasScopeFields(data) {
      return data.keys().hasAny(['teamId', 'team', 'categorie', 'subCategory']);
    }

    function canAccessScopedData(data) {
      return !hasTeamScope()
        || !hasScopeFields(data)
        || canAccessTeam(valueOrEmpty(data, 'teamId'))
        || canAccessTeam(valueOrEmpty(data, 'team'))
        || canAccessTeam(valueOrEmpty(data, 'categorie'))
        || canAccessTeam(valueOrEmpty(data, 'subCategory'));
    }

    function canReadPlayerDoc(playerId, data) {
      return canReadData()
        && canAccessPlayerId(playerId)
        && canAccessScopedData(data);
    }

    function noDelete() {
      return false;
    }

    function isSeedAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && (
          request.auth.token.email.matches('.*maxence\\.boisdron.*')
          || request.auth.token.email == 'sylvain.ostard@gmail.com'
        );
    }

    function isAllowedSelfStaffMaintenance(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastLoginAt', 'email']);
    }

    function isAllowedSeedAdminRepair(uid) {
      return signedIn()
        && request.auth.uid == uid
        && isSeedAdminEmail()
        && request.resource.data.permissionLevel == 'ADMIN'
        && request.resource.data.role == 'ADMIN'
        && request.resource.data.status == 'ACTIVE'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastLoginAt', 'email', 'legacyRole', 'role', 'roleLabel', 'permissionLevel', 'permissionLabel', 'allowedModules', 'status']);
    }

    match /staff_members/{uid} {
      allow read: if canManageUsers() || (signedIn() && request.auth.uid == uid);
      allow create: if canManageUsers()
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.role in ['RESPONSABLE_POLE', 'ENTRAINEUR', 'ENTRAINEUR_ADJOINT', 'PREPARATEUR_PHYSIQUE', 'KINE', 'MEDECIN', 'DIRIGEANT', 'EDUCATEUR', 'COACH', 'LECTURE', 'OBSERVATEUR_STAFF']
          && request.resource.data.permissionLevel in ['LECTEUR', 'SAISIE', 'EDITEUR']
          && request.resource.data.status == 'ACTIVE'
        )
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.permissionLevel == 'ADMIN'
          && isSeedAdminEmail()
          && request.resource.data.status == 'ACTIVE'
        );
      allow update: if canManageUsers() || isAllowedSelfStaffMaintenance(uid) || isAllowedSeedAdminRepair(uid);
      allow delete: if noDelete();
    }

    match /coachpulse_common_base/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
      allow delete: if noDelete();
    }

    match /players/{playerId} {
      allow read: if canReadPlayerDoc(playerId, resource.data) && (canAccessModule('database') || canAccessModule('playerProfile'));
      allow create, update: if canManageCoreData()
        && canAccessModule('database')
        && request.resource.data.playerId == playerId
        && request.resource.data.status in ['ACTIVE', 'ARCHIVED', 'active', 'injured', 'left', 'archived']
        && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /teams/{teamId} {
      allow read: if canReadData() && canAccessTeam(teamId);
      allow create, update: if canManageCoreData()
        && request.resource.data.teamId == teamId
        && canAccessTeam(teamId);
      allow delete: if noDelete();
    }

    match /settings/{settingsId} {
      allow read: if canReadData();
      allow create, update: if canManageCoreData();
      allow delete: if noDelete();
    }

    match /changeLogs/{changeLogId} {
      allow read: if canManageCoreData();
      allow create: if canManageCoreData();
      allow update, delete: if noDelete();
    }

    match /syncLogs/{syncLogId} {
      allow read: if canManageCoreData();
      allow create: if canManageCoreData();
      allow update, delete: if noDelete();
    }

    match /matches/{matchId} {
      allow read: if (canReadData() && canAccessModule('stats') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('stats') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /matchEvents/{eventId} {
      allow read: if (canReadData() && canAccessModule('stats') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('stats') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /sessions/{sessionId} {
      allow read: if (canReadData() && canAccessModule('methodologie') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('methodologie') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /attendance/{attendanceId} {
      allow read: if (canReadData() && canAccessModule('presences') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('presences') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /technicalTests/{testId} {
      allow read: if (canReadData() && canAccessModule('tests') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('tests') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /physicalTests/{testId} {
      allow read: if (canReadData() && canAccessModule('tests') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWritePhysicalData() && canAccessModule('tests') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /injuries/{injuryId} {
      allow read: if (canReadMedicalData() && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteMedicalData() && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /injuryUpdates/{updateId} {
      allow read: if (canReadMedicalData() && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteMedicalData() && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /medicalAppointments/{appointmentId} {
      allow read: if (canReadMedicalData() && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteMedicalData() && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /rehabRoutines/{routineId} {
      allow read: if (canReadMedicalData() && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteMedicalData() && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /medicalFollowUps/{followUpId} {
      allow read: if (canReadMedicalData() && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteMedicalData() && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /workloads/{workloadId} {
      allow read: if (canReadData() && canAccessModule('workload') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWritePhysicalData() && canAccessModule('workload') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /convocations/{convocationId} {
      allow read: if (canReadData() && canAccessModule('convocations') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('convocations') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /individualReports/{reportId} {
      allow read: if (canReadData() && canAccessModule('individualReports') && canAccessScopedData(resource.data)) || canReadPlayerProfileData(resource.data);
      allow create, update: if canWriteSportData() && canAccessModule('individualReports') && canAccessScopedData(request.resource.data);
      allow delete: if noDelete();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
